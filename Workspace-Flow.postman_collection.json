{
  "info": {
    "_postman_id": "9a6e7f0a-8b3b-4f6e-b1ef-2df7177b3b2a",
    "name": "Workspace Flow API",
    "description": "Postman collection for the Workspace Flow backend. Start with Register or Login, then use the authenticated notes/profile requests. Login stores `token`; Create Note stores `noteId`.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    },
    {
      "key": "noteId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "health"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Identity",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abdelfatah User\",\n  \"email\": \"abdelfatah@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/register",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "register"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) {",
                  "  pm.collectionVariables.set('token', json.token);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"abdelfatah@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "login"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Current Session",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/me",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "me"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Profile",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Abdelfatah Updated\",\n  \"email\": \"abdelfatah.updated@example.com\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/auth/profile",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "profile"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Account",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/auth/account",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "account"
              ]
            },
            "description": "Deletes the authenticated account permanently. Use carefully."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Notes",
      "item": [
        {
          "name": "Browse Notes",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes?search=project&category=Work&status=private",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notes"
              ],
              "query": [
                {
                  "key": "search",
                  "value": "project",
                  "description": "Optional text search."
                },
                {
                  "key": "category",
                  "value": "Work",
                  "description": "Optional category filter."
                },
                {
                  "key": "status",
                  "value": "private",
                  "description": "Optional status filter: private or public."
                }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Note",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "const id = json.data && (json.data._id || json.data.id);",
                  "if (id) {",
                  "  pm.collectionVariables.set('noteId', id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Project Plan\",\n  \"content\": \"Draft the first workspace flow plan.\",\n  \"category\": \"Work\",\n  \"tags\": [\n    \"planning\",\n    \"backend\"\n  ],\n  \"status\": \"private\",\n  \"is_pinned\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notes",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notes"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Inspect Note",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notes",
                "{{noteId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Update Note",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Project Plan\",\n  \"content\": \"Add API testing steps and validation notes.\",\n  \"category\": \"Work\",\n  \"tags\": [\n    \"planning\",\n    \"postman\"\n  ],\n  \"status\": \"public\",\n  \"is_pinned\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notes",
                "{{noteId}}"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Delete Note",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{token}}",
                  "type": "string"
                }
              ]
            },
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/notes/{{noteId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "notes",
                "{{noteId}}"
              ]
            }
          },
          "response": []
        }
      ]
    }
  ]
}
